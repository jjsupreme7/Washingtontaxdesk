# Database
DATABASE_URL="postgresql://user:password@localhost:5432/washington_tax_desk?schema=public"

# API Keys
# Get your Claude API key from: https://console.anthropic.com/
CLAUDE_API_KEY="your_claude_api_key_here"

# Get your CustomGPT API key from your CustomGPT account
CUSTOMGPT_API_KEY="your_customgpt_api_key_here"

# NextAuth Configuration
# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-key-change-this-in-production"

# Application URLs
# For local development:
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# For production, change to your domain:
# NEXTAUTH_URL="https://washingtontaxdesk.com"
# NEXT_PUBLIC_APP_URL="https://washingtontaxdesk.com"
